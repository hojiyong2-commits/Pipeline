{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(*)",
      "PowerShell(*)",
      "Edit(*)",
      "Write(*)",
      "Read",
      "Grep",
      "Glob",
      "Agent(*)",
      "ToolSearch",
      "TodoWrite",
      "Skill(*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ]
  },
  "skipDangerousModePermissionPrompt": true,
  "hooks": {
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -File \".claude/hooks/codex-user-acceptance-review.ps1\" -TranscriptPath \"$CLAUDE_HOOK_TRANSCRIPT_PATH\""
          }
        ]
      }
    ]
  }
}
