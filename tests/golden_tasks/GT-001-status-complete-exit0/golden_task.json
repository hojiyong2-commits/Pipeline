{
  "id": "GT-001-status-complete-exit0",
  "description": "pipeline.py status 명령이 완료된 파이프라인에 대해 exit code 0을 반환하는지 검증",
  "command": "python pipeline.py status",
  "smoke": true,
  "allowed_files": [
    "pipeline_state.json"
  ],
  "forbidden_files": [
    "scope_manifest*.json",
    "module_design_*.xml",
    "module_handover_*.xml",
    "module_qa_*.xml"
  ],
  "acceptance_criteria": [
    "exit_code == 0",
    "stdout contains '파이프라인'"
  ],
  "return_phase": "dev"
}
