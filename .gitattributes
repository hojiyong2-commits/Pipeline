# Force LF for generated evidence files.
# Without this, Windows git autocrlf converts LF->CRLF on checkout, breaking SHA-256 checks
# in the phase attestation CI step. pipeline.py writes JSON as UTF-8 bytes with LF.
*.xml text eol=lf
*.json text eol=lf
*.md text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.bandit text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.example text eol=lf
.env* text eol=lf
